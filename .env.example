# Go API Base - Environment Configuration
# Copy this file to .env and update values as needed

# =============================================================================
# Server Configuration
# =============================================================================
SERVER_PORT=8080
GIN_MODE=debug
LOG_LEVEL=info

# =============================================================================
# Logging Configuration
# =============================================================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log format: json, text
LOG_FORMAT=json

# Output destinations: comma-separated list of stdout, file, syslog
# Examples: stdout, file, syslog, stdout,file, stdout,syslog
LOG_OUTPUTS=stdout

# File Writer Configuration (required if outputs includes "file")
LOG_FILE_PATH=/var/log/api.log
LOG_FILE_MAX_SIZE=100
LOG_FILE_MAX_BACKUPS=10
LOG_FILE_MAX_AGE=30
LOG_FILE_COMPRESS=true

# Syslog Configuration (required if outputs includes "syslog")
LOG_SYSLOG_NETWORK=                           # tcp, udp, or empty for local
LOG_SYSLOG_ADDRESS=                           # Syslog server address
LOG_SYSLOG_TAG=go-api

# Source Location Configuration
LOG_ADD_SOURCE=false                          # Include file:line in logs (adds overhead)

# =============================================================================
# Database Configuration
# =============================================================================
# Individual connection parameters (for development)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=go_api_base
DATABASE_SSL_MODE=disable

# Full connection string (for production - takes precedence if set)
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/go_api_base?sslmode=disable

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Full Redis URL (for production - takes precedence if set)
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# JWT Authentication
# =============================================================================
# JWT signing secret - REQUIRED, must be at least 32 characters!
# IMPORTANT: No default value - application will NOT start without this.
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# JWT issuer and audience (for token validation)
JWT_ISSUER=go-api-base
JWT_AUDIENCE=api

# Token Time-to-Live settings
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h

# Password reset token expiry
PASSWORD_RESET_TOKEN_EXPIRY=1h

# =============================================================================
# Security Settings
# =============================================================================
# Password hashing cost (10-12 recommended, higher = slower but more secure)
BCRYPT_COST=10

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# =============================================================================
# Feature Flags
# =============================================================================
# Enable/disable user registration
ENABLE_REGISTRATION=true

# Enable/disable email verification requirement
REQUIRE_EMAIL_VERIFICATION=false

# =============================================================================
# Production Overrides (uncomment for production)
# =============================================================================
# GIN_MODE=release
# LOG_LEVEL=info
# DATABASE_SSL_MODE=verify-ca
# =============================================================================
# Storage Configuration
# =============================================================================
# Storage driver: local, s3, minio
STORAGE_DRIVER=local

# Local storage settings
STORAGE_LOCAL_PATH=./storage/uploads
STORAGE_BASE_URL=http://localhost:8080/storage

# S3/MinIO settings (required when STORAGE_DRIVER=s3 or minio)
# STORAGE_S3_ENDPOINT=https://s3.amazonaws.com  # Empty for AWS S3, set for MinIO
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_BUCKET=your-bucket-name
# STORAGE_S3_ACCESS_KEY=your-access-key
# STORAGE_S3_SECRET_KEY=your-secret-key
# STORAGE_S3_USE_SSL=true
# STORAGE_S3_PATH_STYLE=false  # true for MinIO, false for AWS S3

# =============================================================================
# Image Compression Configuration
# =============================================================================
# Enable/disable image compression
IMAGE_COMPRESSION_ENABLED=true

# Thumbnail settings (quality: 1-100, size: 1-4096)
IMAGE_COMPRESSION_THUMBNAIL_QUALITY=85
IMAGE_COMPRESSION_THUMBNAIL_WIDTH=300
IMAGE_COMPRESSION_THUMBNAIL_HEIGHT=300

# Preview settings
IMAGE_COMPRESSION_PREVIEW_QUALITY=90
IMAGE_COMPRESSION_PREVIEW_WIDTH=800
IMAGE_COMPRESSION_PREVIEW_HEIGHT=600

# =============================================================================
# Cache Configuration
# =============================================================================
# Cache driver: redis, memory, none
CACHE_DRIVER=redis
CACHE_DEFAULT_TTL=300
CACHE_PERMISSION_TTL=300
CACHE_RATE_LIMIT_TTL=60

# =============================================================================
# Swagger Configuration
# =============================================================================
# Enable/disable Swagger documentation UI
SWAGGER_ENABLED=true
SWAGGER_PATH=/swagger

# =============================================================================
# Email Service Configuration
# =============================================================================
# Email provider: smtp, sendgrid, ses
EMAIL_PROVIDER=smtp

# SMTP settings (required when EMAIL_PROVIDER=smtp)
EMAIL_SMTP_HOST=localhost
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_FROM_ADDRESS=noreply@example.com
EMAIL_SMTP_FROM_NAME=Go API Base

# Email queue settings
EMAIL_WORKER_CONCURRENCY=10    # Number of concurrent email workers
EMAIL_RETRY_MAX=5              # Maximum retry attempts per email
EMAIL_RATE_LIMIT_PER_HOUR=100  # Max emails per hour per user
