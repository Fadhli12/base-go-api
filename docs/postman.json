              }
            ],
            "url": {
              "raw": "{{base_url}}/roles/{{role_id}}/permissions/{{permission_id}}",
              "host": ["{{base_url}}"],
              "path": ["roles", "{{role_id}}", "permissions", "{{permission_id}}"]
            },
            "description": "Detach a permission from a role"
          }
        }
      ]
    },
