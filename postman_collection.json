{
	"info": {
		"_postman_id": "go-api-auth-collection",
		"name": "Go API - Auth & RBAC",
		"description": "Postman collection for testing authentication and RBAC features in Go API Base project.\n\n**Authentication:**\n- Public endpoints (register, login, password reset) require no auth\n- Protected endpoints require `Authorization: Bearer {{access_token}}`\n\n**Password Requirements:**\n- 8-72 characters\n- At least 1 uppercase letter\n- At least 1 lowercase letter\n- At least 1 number\n- At least 1 special character (!@#$%^&*(),.?\\\":{}|<>)\n\n**Response Format:**\nAll responses wrapped in `{\"data\": {...}, \"error\": {...}, \"meta\": {...}}`",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{access_token}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Auto-save access_token from login/refresh responses",
					"if (pm.response.code === 200) {",
					"    const json = pm.response.json();",
					"    if (json.data && json.data.access_token) {",
					"        pm.collectionVariables.set('access_token', json.data.access_token);",
					"        if (json.data.refresh_token) {",
					"            pm.collectionVariables.set('refresh_token', json.data.refresh_token);",
					"        }",
					"    }",
					"    if (json.data && json.data.user && json.data.user.id) {",
					"        pm.collectionVariables.set('user_id', json.data.user.id);",
					"    }",
					"}"
				]
			}
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "access_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "refresh_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "user_id",
			"value": "",
			"type": "string"
		}
	],
